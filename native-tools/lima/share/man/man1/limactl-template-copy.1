.SH NAME
limactl-template-copy - Copy template


.SH SYNOPSIS
\fBlimactl template copy [OPTIONS] TEMPLATE [DEST] [flags]\fP


.SH DESCRIPTION
Copy a template via locator to a local file or stdout (default)


.SH OPTIONS
\fB--embed\fP[=false]
	Embed external dependencies into template

.PP
\fB--embed-all\fP[=false]
	Embed all dependencies into template

.PP
\fB--fill\fP[=false]
	Fill defaults

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for copy

.PP
\fB--verbatim\fP[=false]
	Don't make locators absolute


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Debug mode

.PP
\fB--log-format\fP="text"
	Set the logging format [text, json]

.PP
\fB--log-level\fP=""
	Set the logging level [trace, debug, info, warn, error]

.PP
\fB--tty\fP[=false]
	Enable TUI interactions such as opening an editor. Defaults to true when stdout is a terminal. Set to false for automation.

.PP
\fB-y\fP, \fB--yes\fP[=false]
	Alias of --tty=false


.SH EXAMPLE
.EX
  Template locators are local files, file://, https://, or template: URLs

  # Copy default template to STDOUT
  limactl template copy template:default -

  # Copy template from web location to local file and embed all external references
  # (this does not embed template: references)
  limactl template copy --embed https://example.com/lima.yaml mighty-machine.yaml

.EE


.SH SEE ALSO
\fBlimactl-template(1)\fP
