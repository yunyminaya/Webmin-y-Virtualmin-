# Ejemplo seguro: copiar a un archivo local ignorado por Git y completar valores reales.
# Nunca guardar contraseñas, tokens, claves privadas ni hosts internos reales en el repositorio.

OPENVM_SSH_USER=admin-user
OPENVM_SSH_KEY=/secure/local/path/openvm_ed25519
OPENVM_SRV1_HOST=server-1.example.internal
OPENVM_SRV2_HOST=server-2.example.internal
OPENVM_DOMAIN_PASSWORD=generate-at-runtime-or-use-secret-manager
OPENVM_WEBMIN_PORT=10000

# Secret managers recomendados:
# - 1Password CLI
# - Bitwarden CLI
# - HashiCorp Vault
# - AWS Secrets Manager / GCP Secret Manager / Azure Key Vault
