# =============================================================================
# ARCHIVO .GITIGNORE - WEBMIN/VIRTUALMIN
# =============================================================================
# Protege archivos sensibles y temporales
# ============================================================================

# ARCHIVOS DE CONFIGURACIÓN SENSIBLES
# =============================================================================
# Archivos de entorno con credenciales reales
.env.production
.env.local
.env.staging
.env.development

# Archivos de credenciales
*.key
*.pem
*.crt
credentials.txt
passwords.txt
api_keys.txt

# LOGS DE INSTALACIÓN Y VALIDACIÓN
/tmp/webmin_*.log
/tmp/installation_*.log
/tmp/validation_*.log

# ARCHIVOS TEMPORALES
/tmp/
temp/
*.temp

# SCRIPTS DE INSTALACIÓN
install_webmin_ubuntu.sh
install_webmin_simple.sh
