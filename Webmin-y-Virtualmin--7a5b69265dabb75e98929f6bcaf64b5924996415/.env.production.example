# =============================================================================
# ARCHIVO DE CONFIGURACIÓN DE ENTORNO SEGURA - WEBMIN/VIRTUALMIN
# Copiar este archivo a .env.production y configurar los valores reales
# =============================================================================
#
# ⚠️  IMPORTANTE: Nunca commits este archivo con valores reales al repositorio!
#    Solo mantener el archivo .example con valores de ejemplo
#

# =============================================================================
# CONFIGURACIÓN DE SERVIDOR
# =============================================================================

# Dominio principal para el servidor
SERVER_DOMAIN=example.com

# Dirección IP del servidor (se detecta automáticamente si está vacío)
SERVER_IP=

# Nombre del servidor
SERVER_HOSTNAME=webmin-server

# =============================================================================
# CONFIGURACIÓN DE WEBMIN
# =============================================================================

# Puerto de Webmin (por defecto: 10000)
WEBMIN_PORT=10000

# Usuario administrativo de Webmin
WEBMIN_ADMIN_USER=root

# Contraseña de Webmin (dejar vacío para generar automáticamente)
WEBMIN_ADMIN_PASSWORD=

# Habilitar SSL en Webmin (true/false)
WEBMIN_SSL_ENABLED=true

# =============================================================================
# CONFIGURACIÓN DE VIRTUALMIN
# =============================================================================

# Email del administrador
ADMIN_EMAIL=admin@example.com

# Nombre de la organización
ORGANIZATION_NAME=Mi Organización

# País (código ISO)
COUNTRY_CODE=US

# =============================================================================
# CONFIGURACIÓN DE BASE DE DATOS
# =============================================================================

# Tipo de base de datos (mysql/mariadb/postgresql)
DB_TYPE=mysql

# Contraseña de root de base de datos (dejar vacío para generar automáticamente)
DB_ROOT_PASSWORD=

# Nombre de la base de datos principal
DB_NAME=virtualmin

# Usuario de la base de datos
DB_USER=virtualmin

# Contraseña del usuario de base de datos (dejar vacío para generar automáticamente)
DB_PASSWORD=

# =============================================================================
# CONFIGURACIÓN DE SEGURIDAD
# =============================================================================

# Habilitar firewall (true/false)
FIREWALL_ENABLED=true

# Habilitar Fail2Ban (true/false)
FAIL2BAN_ENABLED=true

# Tiempo de baneo en segundos (3600 = 1 hora)
FAIL2BAN_BANTIME=3600

# Máximo de intentos antes de banear
FAIL2BAN_MAXRETRY=3

# =============================================================================
# CONFIGURACIÓN DE SSL/TLS
# =============================================================================

# Habilitar Let's Encrypt (true/false)
LETSENCRYPT_ENABLED=true

# Email para Let's Encrypt
LETSENCRYPT_EMAIL=admin@example.com

# Tipo de certificado (letsencrypt/selfsigned/custom)
SSL_CERT_TYPE=letsencrypt

# Ruta al certificado personalizado (si SSL_CERT_TYPE=custom)
SSL_CERT_PATH=

# Ruta a la clave privada (si SSL_CERT_TYPE=custom)
SSL_KEY_PATH=

# =============================================================================
# CONFIGURACIÓN DE BACKUP
# =============================================================================

# Habilitar backup automático (true/false)
BACKUP_ENABLED=true

# Frecuencia de backup (daily/weekly/monthly)
BACKUP_FREQUENCY=daily

# Ruta de almacenamiento de backups
BACKUP_PATH=/var/backups/webmin

# Días de retención de backups
BACKUP_RETENTION_DAYS=30

# =============================================================================
# CONFIGURACIÓN DE MONITOREO
# =============================================================================

# Habilitar monitoreo (true/false)
MONITORING_ENABLED=true

# Puerto del dashboard de monitoreo
MONITORING_PORT=8080

# Email para alertas de monitoreo
MONITORING_EMAIL=admin@example.com

# =============================================================================
# CONFIGURACIÓN MULTI-NUBE (OPCIONAL)
# =============================================================================

# Proveedor cloud (aws/gcp/azure/none)
CLOUD_PROVIDER=none

# Región cloud
CLOUD_REGION=

# Access Key ID (solo para AWS)
AWS_ACCESS_KEY_ID=

# Secret Access Key (solo para AWS)
AWS_SECRET_ACCESS_KEY=

# Project ID (solo para GCP)
GCP_PROJECT_ID=

# Subscription ID (solo para Azure)
AZURE_SUBSCRIPTION_ID=

# =============================================================================
# CONFIGURACIÓN DE FIREWALL INTELIGENTE
# =============================================================================

# Habilitar firewall inteligente (true/false)
INTELLIGENT_FIREWALL_ENABLED=true

# Nivel de sensibilidad (low/medium/high)
FIREWALL_SENSITIVITY=medium

# Habilitar machine learning (true/false)
FIREWALL_ML_ENABLED=true

# =============================================================================
# CONFIGURACIÓN DE IDS/IPS
# =============================================================================

# Habilitar IDS/IPS (true/false)
IDS_IPS_ENABLED=true

# Nivel de detección (low/medium/high)
IDS_SENSITIVITY=medium

# =============================================================================
# CONFIGURACIÓN DE ZERO TRUST
# =============================================================================

# Habilitar Zero Trust (true/false)
ZERO_TRUST_ENABLED=true

# Tiempo de expiración de sesión en segundos
SESSION_TIMEOUT=3600

# =============================================================================
# CONFIGURACIÓN DE OPTIMIZACIÓN IA
# =============================================================================

# Habilitar optimización con IA (true/false)
AI_OPTIMIZATION_ENABLED=true

# Frecuencia de optimización (hourly/daily/weekly)
AI_OPTIMIZATION_FREQUENCY=daily

# =============================================================================
# VARIABLES DE ENTORNO DEL SISTEMA
# =============================================================================

# Zona horaria
TIMEZONE=UTC

# Idioma del sistema
SYSTEM_LOCALE=en_US.UTF-8

# =============================================================================
# RUTAS PERSONALIZADAS
# =============================================================================

# Directorio de instalación personalizado
INSTALL_DIR=/opt/webmin-virtualmin

# Directorio de logs personalizado
LOG_DIR=/var/log/webmin-virtualmin

# Directorio de configuración personalizado
CONFIG_DIR=/etc/webmin-virtualmin

# =============================================================================
# CONFIGURACIÓN AVANZADA
# =============================================================================

# Nivel de log (DEBUG/INFO/WARN/ERROR)
LOG_LEVEL=INFO

# Habilitar modo debug (true/false)
DEBUG_MODE=false

# Puerto para API (si está habilitada)
API_PORT=8081

# Token de API (dejar vacío para generar automáticamente)
API_TOKEN=

# =============================================================================
# NOTAS IMPORTANTES
# =============================================================================

# 1. Todos los valores marcados como "dejar vacío para generar automáticamente"
#    se generarán de forma segura durante la instalación si no se especifican.
#
# 2. Las contraseñas generadas automáticamente se guardarán en:
#    /root/webmin_credentials.txt con permisos 600
#
# 3. Para mayor seguridad, se recomienda usar variables de entorno
#    en lugar de este archivo para valores sensibles:
#
#    export WEBMIN_ADMIN_PASSWORD="tu_contraseña_segura"
#    export DB_ROOT_PASSWORD="tu_contraseña_db"
#
# 4. Este archivo debe tener permisos 600:
#    chmod 600 .env.production
#
# 5. Nunca incluir este archivo con valores reales en commits
#    al repositorio Git.
#
# =============================================================================